{
  // Scheduled refresh time in real-world local time.
  "refresh_hour": 6,
  "refresh_minute": 0,

  "levels": {
    // Levels 1-3 use gold ingots by default as the base currency.
    "1": {
      "observe_currency": "magic_coins:gold_coin",
      "observe_cost": 2,
      "redeem_currency": "magic_coins:gold_coin",
    },
    "2": {
      "observe_currency": "magic_coins:gold_coin",
      "observe_cost": 4,
      "redeem_currency": "magic_coins:gold_coin",
    },
    "3": {
      "observe_currency": "magic_coins:gold_coin",
      "observe_cost": 8,
      "redeem_currency": "magic_coins:gold_coin",
    },

    // Levels 4-5 use emeralds by default for higher variance rewards.
    "4": {
      "observe_currency": "magic_coins:crystal_coin",
      "observe_cost": 3,
      "redeem_currency": "magic_coins:crystal_coin",
    },
    "5": {
      "observe_currency": "magic_coins:crystal_coin",
      "observe_cost": 6,
      "redeem_currency": "magic_coins:crystal_coin",
    },
  },
}
